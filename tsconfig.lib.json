{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "build",
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/index.ts"
  ]
}
