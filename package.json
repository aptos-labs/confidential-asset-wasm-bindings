{
  "name": "@aptos-labs/confidential-asset-bindings",
  "version": "1.0.0",
  "description": "Bindings for Aptos confidential asset (discrete log + range proofs)",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "type": "module",
  "module": "./dist/index.mjs",
  "react-native": "./dist/index.native.js",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.native.d.ts",
        "default": "./dist/index.native.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "android",
    "ios",
    "expo-module.config.json"
  ],
  "scripts": {
    "build:wasm": "./scripts/build-wasm.sh",
    "build:android": "./scripts/build-android.sh",
    "build:ios": "./scripts/build-ios.sh",
    "build:bindings": "npm run build:wasm && npm run build:android && npm run build:ios",
    "build:lib": "tsdown",
    "build:expo": "expo-module build -p tsconfig.json --outDir dist",
    "build": "npm run build:bindings && npm run build:lib && npm run build:expo",
    "changeset": "changeset",
    "lint": "biome check src examples",
    "lint:fix": "biome format --write src examples",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.lib.json && tsc --noEmit -p examples/browser/tsconfig.json && tsc --noEmit -p examples/expo/tsconfig.json && tsc --noEmit -p examples/node/tsconfig.json",
    "test": "expo-module test",
    "release": "npm run build && changeset publish"
  },
  "keywords": [
    "aptos",
    "confidential",
    "wasm",
    "bulletproofs",
    "discrete-log",
    "range-proof",
    "react-native",
    "expo",
    "@aptos-labs/confidential-asset-bindings",
    "ConfidentialAssetBindings"
  ],
  "repository": "https://github.com/aptos-labs/confidential-asset-bindings",
  "bugs": {
    "url": "https://github.com/aptos-labs/confidential-asset-bindings/issues"
  },
  "author": "aptoslabs <aptoslabs@aptoslabs.com> (https://github.com/aptos-labs)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/aptos-labs/confidential-asset-bindings#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@types/react": "~19.1.1",
    "expo": "^55.0.11",
    "expo-module-scripts": "^55.0.2",
    "react-native": "0.82.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.8.3",
    "wasm-pack": "^0.13.1"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
