{
  "name": "@aptos-labs/confidential-asset-wasm-bindings",
  "version": "0.1.2",
  "description": "Unified WASM bindings for Aptos confidential assets (discrete log + range proofs)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/aptos-labs/confidential-asset-wasm-bindings.git"
  },
  "main": "./aptos_confidential_asset_wasm-cjs.js",
  "module": "./aptos_confidential_asset_wasm-esm.js",
  "types": "./aptos_confidential_asset_wasm.d.ts",
  "exports": {
    ".": {
      "import": "./aptos_confidential_asset_wasm-esm.js",
      "require": "./aptos_confidential_asset_wasm-cjs.js",
      "types": "./aptos_confidential_asset_wasm.d.ts"
    },
    "./*.wasm": "./aptos_confidential_asset_wasm_bg.wasm"
  },
  "files": [
    "aptos_confidential_asset_wasm-esm.js",
    "aptos_confidential_asset_wasm-cjs.js",
    "aptos_confidential_asset_wasm.d.ts",
    "*.wasm",
    "*.wasm.d.ts"
  ],
  "keywords": [
    "aptos",
    "confidential",
    "wasm",
    "bulletproofs",
    "discrete-log",
    "range-proof"
  ],
  "license": "Apache-2.0"
}
